local Camera = workspace.CurrentCamera

local function startCameraShake(intensity, duration)
	local shakeConn = RunService.RenderStepped:Connect(function()
		local rx = (math.random() - 0.5) * intensity
		local ry = (math.random() - 0.5) * intensity
		local rz = (math.random() - 0.5) * (intensity * 0.75)
		Camera.CFrame = Camera.CFrame * CFrame.Angles(rx, ry, rz)
	end)

	task.delay(duration, function()
		if shakeConn then shakeConn:Disconnect() end
	end)--

	return shakeConn
end

