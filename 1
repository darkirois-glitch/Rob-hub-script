loadstring(game:HttpGet("https://raw.githubusercontent.com/darkirois-glitch/Rob-hub-script/refs/heads/main/Diaoroedf9d"))()

local Player = game.Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local camera = Workspace.CurrentCamera

local Existing = Player.Backpack:FindFirstChild("Omni Directional Punch")
if Existing then Existing:Destroy() end

local Tool = Instance.new("Tool")
Tool.Name = "Omni Directional Punch"
Tool.RequiresHandle = false
Tool.CanBeDropped = false
Tool.Parent = Player.Backpack

local Asset = game:GetObjects(getcustomasset("Saitama.rbxmx"))[1]
local OmniPlayerAnim = Asset:FindFirstChild("OmniPlayer", true)
local OmniRockLandAnim = Asset:FindFirstChild("OmniRockLand", true)
local OmniLandAnim = Asset:FindFirstChild("OmniLand", true)
local OmniEnemyAnim = Asset:FindFirstChild("OmniEnemy", true)
local OmniDebrisFolder = Asset:FindFirstChild("OmniDebris", true)

local Debounce = false

local function CloneMe(char)
	char.Archivable = true
	local clone = char:Clone()
	char.Archivable = false
	return clone
end

local function CleanupDebris(flyingRocks)
	for _, data in ipairs(flyingRocks) do
		if data.Part then
			data.Part:Destroy()
		end
	end
end

Tool.Activated:Connect(function()
	if Debounce then return end
	Debounce = true

	local Character = Player.Character
	if not Character then Debounce = false return end

	local HRP = Character:FindFirstChild("HumanoidRootPart")
	if not HRP then Debounce = false return end

	local originalPlayerCFrame = HRP.CFrame

	HRP.Anchored = true

	local Sound = Instance.new("Sound")
	Sound.SoundId = getcustomasset("OmniPunch.mp3")
	Sound.Volume = 2
	Sound.Parent = workspace
	Sound:Play()

	local animPlayer = PlayKeyframeSequence(Character, OmniPlayerAnim, 1)

	local flyingRocks = {}
	local centerPointClone = nil
	local landingRockClone = nil

	task.delay(2, function()
		if not OmniDebrisFolder then return end

		local debrisFolder = Instance.new("Folder")
		debrisFolder.Name = "AlsoNot_ElesLeaf"
		debrisFolder.Parent = Workspace

		local raycastParams = RaycastParams.new()
		raycastParams.FilterDescendantsInstances = {Character}
		raycastParams.FilterType = Enum.RaycastFilterType.Exclude

		local rayResult = Workspace:Raycast(
			HRP.Position + Vector3.new(0,50,0),
			Vector3.new(0,-200,0),
			raycastParams
		)

		local groundColor = BrickColor.new("Brown").Color
		local groundMaterial = Enum.Material.Grass

		if rayResult then
			groundColor = rayResult.Instance.Color
			groundMaterial = rayResult.Instance.Material
		end

		for _, original in ipairs(OmniDebrisFolder:GetDescendants()) do
			if original:IsA("BasePart") then
				local rock = original:Clone()

				rock.Anchored = true
				rock.CanCollide = false

				if not (original.Name == "CenterPoint" or original.Name:match("Line")) then
					rock.Color = groundColor
					rock.Material = groundMaterial
				end

				rock.CFrame = original.CFrame * CFrame.new(-171, 350, -12)

				rock.Parent = debrisFolder

				table.insert(flyingRocks, {
					Part = rock
				})

				if original.Name == "CenterPoint" then
					centerPointClone = rock
				elseif original.Name == "LandingRock" then
					landingRockClone = rock
				end
			end
		end
	end)

	task.wait(2)

	local closestChar = nil
	local closestDist = 30
	local forward = HRP.CFrame.LookVector

	for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
		if otherPlayer ~= Player and otherPlayer.Character then
			local otherHRP = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
			if otherHRP then
				local toTarget = (otherHRP.Position - HRP.Position)
				local dist = toTarget.Magnitude
				if dist < closestDist and dist > 0 then
					local dot = forward:Dot(toTarget.Unit)
					if dot > 0.35 then
						closestDist = dist
						closestChar = otherPlayer.Character
					end
				end
			end
		end
	end

	if not closestChar then
		task.wait(0.7)
		Sound:Stop()
		if animPlayer then animPlayer:Stop(); animPlayer:RestoreAnimator() end
