if not getgenv().Network then 
    getgenv().Network = {
        BaseParts = {},
        Velocity = Vector3.new(0,0,0),
        Instances = {
            AlignPositions = {},
            Torques = {}
        }
    }

    Network.RetainPart = function(v) 
        if v:IsA("BasePart") and not v.Anchored
        and v:IsDescendantOf(workspace) then
            table.insert(Network.BaseParts, v)
            v.CustomPhysicalProperties = PhysicalProperties.new(0,0,0,0,0)
        end
    end

    local function Control()
        plr.ReplicationFocus = workspace
        local con; con = rs.Heartbeat:Connect(function()
            if not getgenv().Network then con:Disconnect() con = nil return end
            sethiddenproperty(plr, "SimulationRadius", math.huge)            
            for i,v in next, getgenv().Network.BaseParts do
                v.Velocity = getgenv().Network.Velocity
            end
        end)
    end
    Control()
end

local function PullPart(v)
    if v:IsA("BasePart") and not v.Anchored and getgenv().Settings.Pulling 
    and not v:IsDescendantOf(char) and v.AssemblyRootPart ~= hrp then

        if v.ClassName == "VehicleSeat" or v.ClassName == "Seat" then 
            v.Disabled = true
        end
        Network.RetainPart(v)
        v.CanCollide = false

        local attachment = Instance.new("Attachment", v)
        local align = Instance.new("AlignPosition", v)        
        align.Attachment0 = attachment
        align.Attachment1 = att
        align.Responsiveness = getgenv().Settings.Responsiveness
        align.MaxForce = math.huge         
        
        local torque = Instance.new("Torque", v)
        torque.Attachment0 = attachment
        torque.Torque = Vector3.new(1000,1000,1000)

        table.insert(getgenv().Network.Instances.AlignPositions, align)
        table.insert(getgenv().Network.Instances.Torques, torque)
    end
end

